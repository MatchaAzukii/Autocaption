{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Autocaption",
  "version": "0.1.0",
  "identifier": "com.autocaption.app",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../webui"
  },
  "app": {
    "windows": [
      {
        "title": "Autocaption",
        "width": 900,
        "height": 600,
        "minWidth": 400,
        "minHeight": 300,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png"
    ]
  }
}
